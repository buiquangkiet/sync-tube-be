# Backend — copy to .env for local Docker
SPRING_PROFILES_ACTIVE=oauth,prod

# Vercel FE URL
FRONTEND_URL=https://your-app.vercel.app

MYSQL_ROOT_PASSWORD=123456
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

BE_PORT=8081

# Railway: set in Railway Dashboard (see RAILWAY.md)
# SPRING_PROFILES_ACTIVE=oauth,prod
# FRONTEND_URL=https://xxx.vercel.app
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE (from MySQL plugin)
# JWT_SECRET, GOOGLE_*, FACEBOOK_*
