# Backend local — dùng cho: docker compose, mvnw spring-boot:run
# Railway: copy giá trị tương ứng lên Railway Dashboard (không push file này)

SPRING_PROFILES_ACTIVE=oauth,prod

# URL frontend (Vercel production)
FRONTEND_URL=https://sync-tube-fe.vercel.app

# Chỉ dùng khi docker compose (MySQL container)
MYSQL_ROOT_PASSWORD=123456

JWT_SECRET=synctube-dev-secret-key-change-in-production-32chars

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

BE_PORT=8081

# Railway thêm riêng trên Dashboard (Reference từ MySQL service):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
